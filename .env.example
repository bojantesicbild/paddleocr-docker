# Copy to .env and edit. docker compose auto-loads .env from the working dir.

# ---- Runtime ---------------------------------------------------------------

# PaddleOCR language code. "ch" is multilingual (CJK + Latin); use "fr", "en",
# etc. for language-specific models.
OCR_LANGUAGE=ch

# Per-job timeout in the RQ worker. Pages that exceed this are marked failed.
OCR_JOB_TIMEOUT=1800

# How long finished (and failed) job results stay in Redis before expiring.
OCR_RESULT_TTL=86400

# Optional. If set, clients must send X-API-Key: <this value>. If unset, the
# /ocr/* and /jobs/* endpoints are open.
# OCR_API_KEY=change-me-to-a-long-random-string


# ---- Networking ------------------------------------------------------------

# Host port to bind. 8090 for local dev, 8080 for prod without TLS. When using
# docker-compose.tls.yml (Caddy), this is unused — Caddy owns 80/443 and talks
# to the paddle-ocr service over the internal Docker network.
HOST_PORT=8090


# ---- TLS (only needed with docker-compose.tls.yml) -------------------------

# Public hostname the service will be served under. Must resolve (via A/AAAA)
# to the machine running Caddy before you bring it up, or the ACME challenge
# will fail.
# DOMAIN=ocr.example.com

# Email for Let's Encrypt account (recovery, expiry warnings).
# CADDY_EMAIL=you@example.com
